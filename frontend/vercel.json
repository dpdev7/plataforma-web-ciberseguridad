{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://backend-web-ciberseguridad.onrender.com/$1",
      "methods": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS"],
      "headers": {
        "X-Forwarded-Host": "backend-web-ciberseguridad.onrender.com"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}